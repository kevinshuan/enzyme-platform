# Global settings (src/config.py -> GlobalSettings, env_prefix=GLOBAL_)
GLOBAL_DATABASE_URL=postgresql://postgres:postgres@db:5432/app_db
GLOBAL_DB_POOL_SIZE=10
GLOBAL_DB_MAX_OVERFLOW=20
GLOBAL_DB_POOL_TIMEOUT=30
GLOBAL_DB_POOL_RECYCLE=1800

# Feature settings examples (use feature-specific prefixes in src/<feature>/config.py)
# USERS_JWT_SECRET=change-me
# PAYMENTS_PROVIDER_API_KEY=change-me
