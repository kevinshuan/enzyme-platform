# Global settings (src/config.py -> GlobalSettings, env_prefix=GLOBAL_)
# GLOBAL_GENERATOR_BACKEND=mock   # or: bionemo  (Phase 2)

# BioNeMo / NVIDIA NIM — Phase 2 sequence generation (env_prefix: none)
# ESM-2 masked-language-model predictions replace random mutation.
# Cloud NIM (NVIDIA API Catalog):
#   BIONEMO_API_KEY=nvapi-...
#   BIONEMO_API_BASE=https://health.api.nvidia.com/v1   (default, omit to use default)
# Self-hosted NIM:
#   docker run --gpus all -p 8080:8080 nvcr.io/nvidia/nim/esm2-650m:latest
#   BIONEMO_API_BASE=http://localhost:8080/v1
# Model path suffix (default: biology/nvidia/esm2-650m):
#   BIONEMO_MODEL=biology/nvidia/esm2-650m
# Sampling temperature — 1.0 = standard; <1 = conservative; >1 = diverse:
#   BIONEMO_TEMPERATURE=1.0
#
# BIONEMO_API_KEY=nvapi-...
# BIONEMO_API_BASE=https://health.api.nvidia.com/v1
# BIONEMO_MODEL=biology/nvidia/esm2-650m
# BIONEMO_TEMPERATURE=1.0

# AlphaFold DB integration (src/enzyme/config.py)
# When set, conserved positions are derived from pLDDT scores via AlphaFold DB API
# instead of config/conserved_regions.json.
#
# Carbonic Anhydrase UniProt IDs:
#   P00915 — Human CA I
#   P00918 — Human CA II (most studied, recommended)
#   P07451 — Human CA III
#
# ALPHAFOLD_UNIPROT_ID=P00918
# ALPHAFOLD_PLDDT_THRESHOLD=90.0   # residues above this are conserved (0–100, default 90)
