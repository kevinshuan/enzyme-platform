# Global settings (src/config.py -> GlobalSettings, env_prefix=GLOBAL_)
# GLOBAL_GENERATOR_BACKEND=mock   # or: bionemo

# AlphaFold DB integration (src/enzyme/config.py)
# When set, conserved positions are derived from pLDDT scores via AlphaFold DB API
# instead of config/conserved_regions.json.
#
# Carbonic Anhydrase UniProt IDs:
#   P00915 — Human CA I
#   P00918 — Human CA II (most studied, recommended)
#   P07451 — Human CA III
#
# ALPHAFOLD_UNIPROT_ID=P00918
# ALPHAFOLD_PLDDT_THRESHOLD=90.0   # residues above this are conserved (0–100, default 90)
